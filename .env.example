# All vars MUST be prefixed with VITE_ to be exposed to the browser.
# These are the PUBLIC, browser-safe values from your Supabase project settings.
# The anon key is safe to expose — Row-Level Security limits what it can do.
# See ../SUPABASE_SETUP.md.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: default storage channel id used when an admin pastes just a message id
# (instead of a full t.me/c/<id>/<msgId> link). Same value as the bot's STORAGE_CHANNEL_ID.
VITE_STORAGE_CHANNEL_ID=
